<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Gambar Klik - Buka Link</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            padding: 20px;
        }
        .container {
            max-width: 600px;
            width: 100%;
            text-align: center;
        }
        /* Link & Gambar */
        .clickable-image {
            display: block;
            width: 100%;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            cursor: pointer;
        }
        .clickable-image:hover {
            transform: scale(1.02);
            box-shadow: 0 20px 30px rgba(0,0,0,0.15);
        }
        .clickable-image img {
            width: 100%;
            height: auto;
            display: block;
        }
        /* Keterangan kecil opsional */
        .info {
            margin-top: 20px;
            font-size: 0.85rem;
            color: #4b5563;
            background: rgba(255,255,255,0.8);
            display: inline-block;
            padding: 6px 14px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
        }
        .info i {
            font-style: normal;
            margin-right: 6px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Ganti href dengan link tujuan Anda -->
        <a href="https://omg10.com/4/10987615" target="_blank" rel="noopener noreferrer" class="clickable-image">
            <!-- Ganti src dengan URL gambar Anda -->
            <img src="https://picsum.photos/id/1015/600/400" alt="Gambar yang bisa diklik">
        </a>
        <div class="info">
          
        </div>
    </div>
</body>
</html>
